# Copy to .env.local for local dev, and add the same keys in Vercel →
# Project → Settings → Environment Variables for production.

# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Any long random string — must match the secret used by the GitHub Actions
# cron workflow (see .github/workflows/reminder.yml). Generate with:
# openssl rand -hex 32
CRON_SECRET=

# Auto-filled by Vercel when you add a Redis database from the Vercel
# Marketplace: Dashboard → your project → Storage → Create Database → Redis
# (Upstash). No need to set these manually if you use that integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
